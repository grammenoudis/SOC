# PostgreSQL (used by Docker Compose)
POSTGRES_USER=soc
POSTGRES_PASSWORD=soc_password_2026
POSTGRES_DB=soc

# API
DATABASE_URL=postgresql://soc:soc_password_2026@db:5432/soc
BETTER_AUTH_SECRET=soc-platform-secret-key-change-in-production-2026
BETTER_AUTH_URL=http://api:3001
PORT=3001

# AI Chat (OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.1

# AbuseIPDB — IP reputation enrichment (get a free key at abuseipdb.com)
ABUSEIPDB_API_KEY=your-abuseipdb-api-key-here

# Logger (syslog listener on UDP 514)
# Set LOGGER_WORKSPACE_ID to a workspace ID from the web UI to enable LLM ingestion.
# Leave empty to run in listen-only mode.
LOGGER_WORKSPACE_ID=
LOGGER_LLM_MODEL=gpt-4.1-mini
LOGGER_BATCH_SIZE=10
LOGGER_FLUSH_INTERVAL=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
