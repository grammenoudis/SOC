generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Better Auth tables ──────────────────────────────────────────

model user {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("analyst") // admin | analyst
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      session[]
  accounts      account[]
  favorites     FavoriteCompany[]
  conversations Conversation[]
  assignedAlerts  Alert[]
  alertActivities AlertActivity[]
  alertNotes      AlertNote[]
}

model session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Domain tables ───────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces Workspace[]
  favoritedBy FavoriteCompany[]

  @@map("companies")
}

model FavoriteCompany {
  userId    String
  companyId String
  createdAt DateTime @default(now())

  user    user    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@map("favorite_companies")
}

model Workspace {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  description         String?
  autoResponseEnabled Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logs    Log[]
  alerts  Alert[]

  @@map("workspaces")
}

model Log {
  id             String   @id @default(cuid())
  workspaceId    String
  timestamp      Int      // Unix epoch
  severity       String   // unknown | low | medium | high | critical
  vendor         String   // e.g. "paloalto"
  eventType      String   // e.g. "traffic", "threat", "system"
  action         String?  // e.g. "allow", "deny", "drop"
  application    String?  // e.g. "soap", "ssl", "web-browsing"
  protocol       String?  // e.g. "tcp", "udp"
  policy         String?  // e.g. "Allow Tap Traffic"
  sourceIp       String?
  sourcePort     Int?
  destinationIp  String?
  destinationPort Int?
  rawLog         String   // Full raw log text
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, timestamp])
  @@index([workspaceId, severity])
  @@index([workspaceId, vendor])
  @@index([sourceIp])
  @@index([destinationIp])
  @@map("logs")
}

model Alert {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  description String
  severity    String   // low | medium | high | critical
  status      String   @default("open") // open | acknowledged | investigating | resolved
  assigneeId  String?
  sourceIp    String?
  destinationIp String?
  logCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee   user?           @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  activities AlertActivity[]
  notes      AlertNote[]

  @@index([workspaceId, status])
  @@index([assigneeId])
  @@index([severity])
  @@map("alerts")
}

model AlertActivity {
  id        String   @id @default(cuid())
  alertId   String
  userId    String
  action    String   // assigned, unassigned, status_changed
  detail    String?  // e.g. "open -> investigating" or assignee name
  createdAt DateTime @default(now())

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user  user  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([alertId, createdAt])
  @@index([createdAt])
  @@map("alert_activities")
}

model AlertNote {
  id        String   @id @default(cuid())
  alertId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user  user  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([alertId, createdAt])
  @@map("alert_notes")
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String
  title       String   @default("New conversation")
  companyId   String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user | assistant
  content        String
  logsUsed       Int?     // how many logs the assistant used to answer
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}
