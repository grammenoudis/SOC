generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Better Auth tables ──────────────────────────────────────────

model user {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("analyst") // admin | analyst
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      session[]
  accounts      account[]
  favorites     FavoriteCompany[]
  conversations Conversation[]
  assignedAlerts  Alert[]
  alertActivities AlertActivity[]
  alertNotes      AlertNote[]
  notifications   Notification[]
  analysisRules   AnalysisRule[]
  llmUsages       LlmUsage[]
}

model session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Domain tables ───────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces Workspace[]
  favoritedBy FavoriteCompany[]
  llmUsages   LlmUsage[]

  @@map("companies")
}

model FavoriteCompany {
  userId    String
  companyId String
  createdAt DateTime @default(now())

  user    user    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@map("favorite_companies")
}

model Workspace {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  description         String?
  autoResponseEnabled Boolean  @default(false)
  deviceHost          String?
  devicePort          Int?     @default(22)
  deviceUser          String?
  devicePassword      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logs          Log[]
  alerts        Alert[]
  autoResponses AutoResponse[]

  @@map("workspaces")
}

model Log {
  id             String   @id @default(cuid())
  workspaceId    String
  timestamp      Int      // Unix epoch
  severity       String   // unknown | low | medium | high | critical
  vendor         String   // e.g. "paloalto"
  eventType      String   // e.g. "traffic", "threat", "system"
  action         String?  // e.g. "allow", "deny", "drop"
  application    String?  // e.g. "soap", "ssl", "web-browsing"
  protocol       String?  // e.g. "tcp", "udp"
  policy         String?  // e.g. "Allow Tap Traffic"
  sourceIp       String?
  sourcePort     Int?
  destinationIp  String?
  destinationPort Int?
  srcCountry     String?
  dstCountry     String?
  rawLog         String   // Full raw log text
  analyzed       Boolean  @default(false)
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, timestamp])
  @@index([workspaceId, severity])
  @@index([workspaceId, vendor])
  @@index([sourceIp])
  @@index([destinationIp])
  @@index([analyzed, workspaceId])
  @@map("logs")
}

model Alert {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  description String
  severity    String   // low | medium | high | critical
  status      String   @default("open") // open | acknowledged | investigating | resolved
  assigneeId  String?
  sourceIp    String?
  destinationIp String?
  logCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee      user?           @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  activities    AlertActivity[]
  notes         AlertNote[]
  notifications Notification[]
  autoResponse  AutoResponse?

  @@index([workspaceId, status])
  @@index([assigneeId])
  @@index([severity])
  @@map("alerts")
}

model AutoResponse {
  id          String   @id @default(cuid())
  alertId     String   @unique
  workspaceId String
  vendor      String
  reasoning   String
  status      String   @default("pending") // pending | executing | completed | failed | recommended
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  alert     Alert                @relation(fields: [alertId], references: [id], onDelete: Cascade)
  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  commands  AutoResponseCommand[]

  @@index([workspaceId, status])
  @@map("auto_responses")
}

model AutoResponseCommand {
  id             String    @id @default(cuid())
  autoResponseId String
  type           String    // block_ip | rate_limit | disable_user | isolate_host | custom
  target         String
  command        String
  reasoning      String
  priority       Int       @default(0)
  status         String    @default("pending") // pending | running | success | failed | skipped
  retryCount     Int       @default(0)
  output         String?
  executedAt     DateTime?
  createdAt      DateTime  @default(now())

  autoResponse AutoResponse @relation(fields: [autoResponseId], references: [id], onDelete: Cascade)

  @@index([autoResponseId, priority])
  @@map("auto_response_commands")
}

model AlertActivity {
  id        String   @id @default(cuid())
  alertId   String
  userId    String
  action    String   // assigned, unassigned, status_changed
  detail    String?  // e.g. "open -> investigating" or assignee name
  createdAt DateTime @default(now())

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user  user  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([alertId, createdAt])
  @@index([createdAt])
  @@map("alert_activities")
}

model AlertNote {
  id        String   @id @default(cuid())
  alertId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user  user  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([alertId, createdAt])
  @@map("alert_notes")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // assigned, unassigned, status_changed, note_added
  title     String
  body      String?
  alertId   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user  user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert Alert? @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model AnalysisRule {
  id          String   @id @default(cuid())
  title       String
  content     String   // natural language rule
  category    String   @default("general") // general, threat, compliance, network, custom
  enabled     Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy user @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([enabled])
  @@map("analysis_rules")
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String
  title       String   @default("New conversation")
  companyId   String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user | assistant
  content        String
  dataUsed       Int?     // total records fetched across all tool calls
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model IpReputation {
  ip             String    @id
  abuseScore     Int       // 0-100
  countryCode    String?
  isp            String?
  domain         String?
  usageType      String?
  totalReports   Int       @default(0)
  lastReportedAt DateTime?
  isPublic       Boolean   @default(true)
  isWhitelisted  Boolean   @default(false)
  checkedAt      DateTime  @default(now())

  @@index([checkedAt])
  @@map("ip_reputation")
}

model LlmUsage {
  id               String   @id @default(cuid())
  userId           String?
  companyId        String?
  workspaceId      String?
  conversationId   String?
  model            String
  purpose          String   // query | answer | title | auto_response
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costUsd          Float    // calculated cost in USD
  createdAt        DateTime @default(now())

  user    user?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("llm_usage")
}
