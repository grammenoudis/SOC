generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Better Auth tables ──────────────────────────────────────────

model user {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("analyst") // admin | analyst
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      session[]
  accounts      account[]
  favorites     FavoriteCompany[]
}

model session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Domain tables ───────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces Workspace[]
  favoritedBy FavoriteCompany[]

  @@map("companies")
}

model FavoriteCompany {
  userId    String
  companyId String
  createdAt DateTime @default(now())

  user    user    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@map("favorite_companies")
}

model Workspace {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  description         String?
  autoResponseEnabled Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logs    Log[]

  @@map("workspaces")
}

model Log {
  id             String   @id @default(cuid())
  workspaceId    String
  timestamp      Int      // Unix epoch
  severity       String   // unknown | low | medium | high | critical
  vendor         String   // e.g. "paloalto"
  eventType      String   // e.g. "traffic", "threat", "system"
  action         String?  // e.g. "allow", "deny", "drop"
  application    String?  // e.g. "soap", "ssl", "web-browsing"
  protocol       String?  // e.g. "tcp", "udp"
  policy         String?  // e.g. "Allow Tap Traffic"
  sourceIp       String?
  sourcePort     Int?
  destinationIp  String?
  destinationPort Int?
  rawLog         String   // Full raw log text
  createdAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, timestamp])
  @@index([workspaceId, severity])
  @@index([workspaceId, vendor])
  @@index([sourceIp])
  @@index([destinationIp])
  @@map("logs")
}
